<Window x:Class="WPFGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoteCheck (with WPF)"
        Height="650" Width="1450"
        MinHeight="400" MinWidth="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="265"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <DockPanel Grid.Column="0" Margin="10,10,5,10" LastChildFill="False">

            <!-- Back button at the top -->
            <Button x:Name="btnBack" Content="Back" Width="60" HorizontalAlignment="Left"
                    Padding="4,2" Margin="0,0,0,16" DockPanel.Dock="Top"
                    Click="btnBack_Click"/>

            <!-- Find by date section -->
            <Label Content="Find by date" Padding="0,0,0,2" DockPanel.Dock="Top"/>
            <TextBox x:Name="tbDate" Margin="0,0,0,4" DockPanel.Dock="Top"
                     KeyDown="tbDate_KeyDown"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" DockPanel.Dock="Top">
                <Button x:Name="btnFindDate" Content="Find" Width="60" HorizontalAlignment="Left"
                        Padding="4,2" Margin="0,0,4,0"
                        Click="btnFindDate_Click"/>
                <Button x:Name="btnToday" Content="Today" Width="60" HorizontalAlignment="Left"
                        Padding="4,2"
                        Click="btnToday_Click"/>
            </StackPanel>

            <!-- Find by surname section -->
            <Label Content="Find by surname" Padding="0,0,0,2" DockPanel.Dock="Top"/>
            <TextBox x:Name="tbSurname" Margin="0,0,0,4" DockPanel.Dock="Top"
                     KeyDown="tbSurname_KeyDown"/>
            <Button x:Name="btnFindSurname" Content="Find" Width="60" HorizontalAlignment="Left"
                    Padding="4,2" Margin="0,0,0,20" DockPanel.Dock="Top"
                    Click="btnFindSurname_Click"/>

            <!-- Amount of queries and Swedish checkbox at the bottom -->
            <CheckBox x:Name="cbSwedish" Content="Swedish?" Margin="0,0,0,8" DockPanel.Dock="Bottom"/>
            <Label x:Name="lblHasMore" Content="Scroll down to find more"
                   Foreground="DarkRed" Padding="0,0,0,4"
                   Visibility="Collapsed" DockPanel.Dock="Bottom"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" DockPanel.Dock="Bottom">
                <Label Content="Amount of queries:" Padding="0,2,4,2" VerticalAlignment="Center"/>
                <TextBox x:Name="tbQueryCount" Text="50" Width="45" VerticalContentAlignment="Center"
                         PreviewTextInput="tbQueryCount_PreviewTextInput"/>
            </StackPanel>
        </DockPanel>

        <!-- Data grid -->
        <DataGrid x:Name="dataGrid" Grid.Column="1" Margin="5,10,10,10"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5"
                  AutoGeneratingColumn="dataGrid_AutoGeneratingColumn"
                  MouseDoubleClick="dataGrid_MouseDoubleClick"/>
    </Grid>
</Window>
