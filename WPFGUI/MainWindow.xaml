<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WPFGUI.MainWindow"
        Title="VoteCheck (with Avalonia)"
        Width="1450" Height="650"
        MinWidth="700" MinHeight="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="265"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <DockPanel Grid.Column="0" Margin="10,10,5,10" LastChildFill="False">

            <!-- Back button at the top -->
            <Button x:Name="btnBack" Content="Back" Width="60" HorizontalAlignment="Left"
                    Padding="4,2" Margin="0,0,0,16" DockPanel.Dock="Top"
                    Click="btnBack_Click"/>

            <!-- Find by date section -->
            <TextBlock Text="Find by date" Margin="0,0,0,2" DockPanel.Dock="Top"/>
            <TextBox x:Name="tbDate" Margin="0,0,0,4" DockPanel.Dock="Top"
                     KeyDown="tbDate_KeyDown"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" DockPanel.Dock="Top">
                <Button x:Name="btnFindDate" Content="Find" Width="60" HorizontalAlignment="Left"
                        Padding="4,2" Margin="0,0,4,0"
                        Click="btnFindDate_Click"/>
                <Button x:Name="btnToday" Content="Today" Width="60" HorizontalAlignment="Left"
                        Padding="4,2"
                        Click="btnToday_Click"/>
            </StackPanel>

            <!-- Find by surname section -->
            <TextBlock Text="Find by surname" Margin="0,0,0,2" DockPanel.Dock="Top"/>
            <TextBox x:Name="tbSurname" Margin="0,0,0,4" DockPanel.Dock="Top"
                     KeyDown="tbSurname_KeyDown"/>
            <Button x:Name="btnFindSurname" Content="Find" Width="60" HorizontalAlignment="Left"
                    Padding="4,2" Margin="0,0,0,20" DockPanel.Dock="Top"
                    Click="btnFindSurname_Click"/>

            <!-- Current MPs section -->
            <TextBlock Text="Current MPs" Margin="0,0,0,2" DockPanel.Dock="Top"/>
            <Button x:Name="btnCurrentMPs" Content="Fetch" Width="60" HorizontalAlignment="Left"
                    Padding="4,2" Margin="0,0,0,20" DockPanel.Dock="Top"
                    Click="btnCurrentMPs_Click"/>

            <!-- Amount of queries and Swedish checkbox at the bottom -->
            <CheckBox x:Name="cbSwedish" Content="Swedish?" Margin="0,0,0,8" DockPanel.Dock="Bottom"/>
            <TextBlock x:Name="lblHasMore" Text="Scroll down to find more"
                       Foreground="DarkRed" Margin="0,0,0,4"
                       IsVisible="False" DockPanel.Dock="Bottom"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" DockPanel.Dock="Bottom">
                <TextBlock Text="Amount of queries:" Margin="0,2,4,2" VerticalAlignment="Center"/>
                <TextBox x:Name="tbQueryCount" Text="50" Width="45"/>
            </StackPanel>
        </DockPanel>

        <!-- Data grid -->
        <DataGrid x:Name="dataGrid" Grid.Column="1" Margin="5,10,10,10"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  DoubleTapped="dataGrid_DoubleTapped">
            <DataGrid.Styles>
                <Style Selector="DataGridRow:nth-child(2n)">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Style>
            </DataGrid.Styles>
        </DataGrid>
    </Grid>
</Window>
